{
  "$schema": "node_modules/wrangler/config-schema.json",
  // True Owner Account: Do.the.carpe.diem@gmail.com,
  "name": "engawa-project",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
